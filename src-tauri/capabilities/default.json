{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the main + pip windows (remote: the hosted app)",
  "windows": ["main", "pip"],
  "remote": {
    "urls": ["https://charlesbennorussell-ctrl.github.io"]
  },
  "permissions": [
    "core:default",
    "global-shortcut:default",
    "core:window:allow-hide",
    "core:window:allow-show",
    "core:window:allow-set-size",
    "core:window:allow-center",
    "allow-set-pip-shortcut",
    "allow-show-main-window"
  ]
}
